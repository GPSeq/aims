{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aims:schema:dataset-manifest:0.1.0",
  "title": "AIMS DatasetManifest",
  "type": "object",
  "required": ["schema_version", "dataset_id", "references", "queries"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "dataset_id": { "type": "string" },
    "description": { "type": "string" },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["uri", "format", "sha256"],
        "properties": {
          "uri": { "type": "string" },
          "format": { "type": "string", "enum": ["fasta", "fastq"] },
          "sha256": { "type": "string" },
          "sequence_count": { "type": "integer", "minimum": 0 },
          "total_bases": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["uri", "format", "sha256"],
        "properties": {
          "uri": { "type": "string" },
          "format": { "type": "string", "enum": ["fasta", "fastq"] },
          "sha256": { "type": "string" },
          "query_length_class": {
            "type": "string",
            "enum": ["short_read", "moderate_sequence", "long_sequence", "mixed"]
          }
        },
        "additionalProperties": false
      }
    },
    "truth_manifest_uri": { "type": "string" },
    "truth_manifest_sha256": { "type": "string" }
  },
  "additionalProperties": false
}
